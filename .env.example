# .env.example

# Server port
PORT=5000

# Database connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/convoy

# Redis connection string (optional for Vercel)
REDIS_URL=redis://127.0.0.1:6379

# Disable Redis for Vercel deployment (set to 'true' for Vercel)
# DISABLE_REDIS=false

# JWT secret for securing tokens
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Environment
NODE_ENV=development

# JWT expiration
JWT_EXPIRE=7d

# Optional: Google Maps API Key for geolocation
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: SMTP settings for email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@fleetmanagement.com

# SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@fleetmanagement.com

# Google Maps API key (optional)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Logging level
LOG_LEVEL=debug

# Queue settings
MAX_QUEUE_RETRIES=3

# Geofencing radius in km
GEOFENCE_RADIUS_KM=5

# Speed alert threshold km/h
SPEED_ALERT_THRESHOLD=120

# Alert cooldown in minutes
ALERT_COOLDOWN_MINUTES=10

# WebSocket settings
WS_PORT=8080
WS_HOST=localhost

# Google Maps API key
GOOGLE_MAPS_API_KEY=

# Application settings
APP_NAME=
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:5000
